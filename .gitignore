# KnowledgeOS .gitignore

# OS files
Thumbs.db
.DS_Store

# Temporary
*.tmp
*.swp

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# Local database (generated automatically via scripts)
knowledge_index.db

# Autopilot runtime state (session briefs, timers)
.knowledgeos/

# Notion Environment variables / local keys
.env
*.env

# Personal / founder residue (never ship in toolkit)
Assets/papers/
pixel art.gif
*.pdf

# Runtime twin artifacts (generated by agents; not product source)
People/Self-Proposals/*.md
Inbox/*-MCP-smoke-capture.md
